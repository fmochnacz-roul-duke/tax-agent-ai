# ── OpenAI credentials ───────────────────────────────────────────────────────
OPENAI_API_KEY=your-key-here

# ── Model configuration (MATE principle — M: Model Efficiency) ───────────────
#
# Three variables give you full control over model tier selection:
#
#   OPENAI_MODEL         — fallback for both tiers if tier-specific vars are not set
#   OPENAI_MODEL_FAST    — cheap/fast model for simple data-retrieval iterations
#                          (check_treaty, get_treaty_rate, check_directive_exemption)
#   OPENAI_MODEL_POWERFUL — capable model for complex legal synthesis iterations
#                          (BO assessment, DEMPE analysis, MLI PPT reasoning, final conclusion)
#
# The agent switches from fast → powerful automatically once substance, DEMPE,
# or MLI data is present in the findings (see selectLlm() in BeneficialOwnerAgent.ts).
#
# Minimum setup — single model for everything (backward-compatible):
#   OPENAI_MODEL=gpt-4o-mini
#
# Two-tier setup — recommended for production runs:
#   OPENAI_MODEL_FAST=gpt-4o-mini
#   OPENAI_MODEL_POWERFUL=gpt-4o
#
# If OPENAI_MODEL_FAST or OPENAI_MODEL_POWERFUL are not set, both tiers fall
# back to OPENAI_MODEL, so existing .env files continue to work unchanged.

OPENAI_MODEL=gpt-4o-mini
OPENAI_MODEL_FAST=gpt-4o-mini
OPENAI_MODEL_POWERFUL=gpt-4o

# ── Phase 6: DDQ Extraction Service ──────────────────────────────────────────
#
# URL of the Python/FastAPI microservice that extracts structured substance
# and DEMPE evidence from DDQ documents.
#
# To enable:
#   1. pip install -r python/requirements.txt
#   2. npm run ddq:service            (starts service on port 8000)
#   3. Set DDQ_SERVICE_URL below
#   4. Add "ddq_path": "data/ddqs/<file>.txt" to your input JSON
#
# When DDQ_SERVICE_URL is not set (or ddq_path is absent from the input JSON),
# the agent falls back to the hardcoded simulation — backward compatible.
#
# DDQ_SERVICE_URL=http://localhost:8000
