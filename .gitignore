# RAG knowledge base — generated files (re-created by npm run rag:build)
# Source files in data/knowledge_base/sources/ ARE tracked (they are the canonical texts)
# Chunks index is tracked (human-readable, useful for review)
# Only the large embedding vectors are excluded
data/knowledge_base/embeddings/vectors.json

# PDF source files — binary, large, re-extractable from originals
data/knowledge_base/sources/originals/*.pdf
