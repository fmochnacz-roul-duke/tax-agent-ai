{
  "name": "tax-agent-ai",
  "version": "1.0.0",
  "description": "AI agent for withholding tax and beneficial owner analysis",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc --noEmit",
    "lint": "eslint src/ scripts/ && prettier --check \"src/**/*.ts\" \"scripts/**/*.ts\"",
    "test": "tsc --noEmit && node --require ts-node/register --test src/**/*.test.ts",
    "test:coverage": "tsc --noEmit && c8 node --require ts-node/register --test src/**/*.test.ts",
    "module1:prompting": "ts-node src/module1/ProgrammaticPrompting.ts",
    "module1:agent": "ts-node src/module1/AgentLoop.ts",
    "module2:tools": "ts-node src/module2/FunctionCallingExample.ts",
    "module2:agent": "ts-node src/module2/AgentLoopFunctionCalling.ts",
    "tax:agent": "ts-node src/agents/BeneficialOwnerAgent.ts",
    "module3:readme": "ts-node src/module3/ReadmeAgent.ts",
    "ddq:service": "python python/run.py",
    "start": "ts-node src/server/index.ts",
    "rag:build": "ts-node scripts/build-knowledge-base.ts",
    "eval": "ts-node scripts/runEvals.ts",
    "verify:treaties": "ts-node scripts/verifyTreaties.ts",
    "review:list": "ts-node scripts/listUnreviewed.ts",
    "test:snapshot:update": "ts-node scripts/updateTreatySnapshot.ts",
    "test:contract:update": "python python/service/export_schemas.py"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "openai": "^6.33.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^25.5.0",
    "@typescript-eslint/eslint-plugin": "^8.58.0",
    "@typescript-eslint/parser": "^8.58.0",
    "c8": "^11.0.0",
    "eslint": "^10.1.0",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.8.1",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.2"
  }
}
